# ClauseGuard v2 — copy to .env and fill in. Never commit the real .env.

# Required: TokenRouter key (OpenAI-compatible). Routes to Claude/GPT/Gemini/Kimi.
TOKENROUTER_API_KEY=your-tokenrouter-key

# Optional: if set, the analyzer uses Anthropic directly (claude-sonnet-4-6)
# instead of TokenRouter. Leave blank to use TokenRouter.
# ANTHROPIC_API_KEY=

# Optional tuning (defaults shown):
# CLAUSEGUARD_MODEL=anthropic/claude-sonnet-4.6   # or anthropic/claude-haiku-4.5 (faster)
# CLAUSEGUARD_LLM_TIMEOUT=150                      # seconds, per analysis call
# CLAUSEGUARD_RATE_LIMIT=5/minute                 # per-IP limit on /api/analyze
