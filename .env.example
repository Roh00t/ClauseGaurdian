# ClauseGuard v2 — copy to .env and fill in. Never commit the real .env.

# Required: TokenRouter key (OpenAI-compatible). Routes to Claude/GPT/Gemini/Kimi.
TOKENROUTER_API_KEY=your-tokenrouter-key

# Optional: if set, the analyzer uses Anthropic directly (claude-sonnet-4-6)
# instead of TokenRouter. Leave blank to use TokenRouter.
# ANTHROPIC_API_KEY=

# Optional tuning (defaults shown):
# CLAUSEGUARD_MODEL=anthropic/claude-sonnet-4.6   # or anthropic/claude-haiku-4.5 (faster)
# CLAUSEGUARD_LLM_TIMEOUT=150                      # seconds, per analysis call
# CLAUSEGUARD_RATE_LIMIT=5/minute                 # per-IP limit on /api/analyze

# Sponsor integrations. All three have graceful fallbacks if unset:
#   Daytona     -> redaction falls back to local regex (LLM still never sees raw text)
#   Bright Data -> MOM regulations fall back to a hardcoded knowledge base
#   Terminal 3  -> HMAC attestation is stdlib; DID is just an identifier string
DAYTONA_API_KEY=your-daytona-key
BRIGHTDATA_API_KEY=your-brightdata-key
TERMINAL3_API_KEY=your-terminal3-key
TERMINAL3_DID=did:your-terminal3-did

# Supabase (v3 auth + metadata storage). NOTE the key names — they differ from
# the older draft: PUBLISHABLE = anon/public key (served to the browser via
# /api/config, safe to expose); SECRET = service-role key (backend only, bypasses
# RLS — never expose). JWKS_URL is informational; tokens are verified via
# auth.get_user(jwt). Leave blank to run anonymously (no login, no backend cap).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-anon-key
SUPABASE_SECRET_KEY=sb_secret_your-service-role-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# PostHog product analytics. POSTHOG_PROJECT_TOKEN is a PUBLIC frontend key
# (phc_...), safe to expose — same trust model as the Supabase publishable key.
# Leave the token blank to disable analytics entirely (no events sent).
POSTHOG_PROJECT_TOKEN=phc_your-project-token
POSTHOG_HOST=https://us.i.posthog.com            # or https://eu.i.posthog.com
# CLAUSEGUARD_DISABLE_ANALYTICS=1                 # force-off (the test suite sets this)
